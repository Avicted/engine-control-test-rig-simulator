# Doxyfile for Engine Control Test Rig Simulator
# Generate with: make docs (or doxygen Doxyfile)

PROJECT_NAME           = "Engine Control Test Rig Simulator"
PROJECT_BRIEF          = "Deterministic engine control loop simulator for safety-critical testing"
PROJECT_NUMBER         = 1.0.0

OUTPUT_DIRECTORY       = build/docs
CREATE_SUBDIRS         = NO

INPUT                  = include/ src/reporting/logger.h src/domain/ src/platform/ src/scenario/ src/app/
FILE_PATTERNS          = *.h *.c
RECURSIVE              = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

OPTIMIZE_OUTPUT_FOR_C  = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

JAVADOC_AUTOBRIEF      = YES
ALIASES                += "requirement=@par Requirement:\n"
ALIASES                += "deterministic=@par Deterministic:\n"
